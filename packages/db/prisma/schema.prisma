generator prisma-client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model Installation {
  id                Int       @id
  accountLogin      String
  accountType       String
  appId             Int
  targetId          Int
  targetType        String
  suspended         Boolean   @default(false)
  encryptedApiKey   String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  webhookDeliveries WebhookDelivery[]
  findings          Finding[]
  tokenUsages       TokenUsage[]

  @@map("installations")
}

model Finding {
  id               String    @id @default(uuid())
  installationId   Int
  repositoryId     Int
  workflowRunId    Int
  checkRunId       Int
  detectorType     String
  sha              String
  ref              String
  violations       Json      @default("[]")
  rawExcerpt       String?
  confidence       Float?
  evidence         String[]  @default([])
  caveat           String?
  rootCause        String?
  suggestedFix     String?
  affectedFiles    String[]  @default([])
  severity         String?
  aiEnrichedAt     DateTime?
  advancedToAction  Boolean   @default(false)
  cyclopsCheckRunId BigInt?
  budgetExceeded    Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  installation     Installation @relation(fields: [installationId], references: [id])

  @@index([installationId])
  @@index([workflowRunId])
  @@index([installationId, createdAt])
  @@map("findings")
}

model TokenUsage {
  id             String   @id @default(uuid())
  installationId Int
  detectorId     String
  model          String
  inputTokens    Int
  outputTokens   Int
  timestamp      DateTime @default(now())

  installation   Installation @relation(fields: [installationId], references: [id])

  @@index([installationId])
  @@index([installationId, timestamp])
  @@map("token_usages")
}

model WebhookDelivery {
  id             String   @id @default(uuid())
  deliveryId     String   @unique
  installationId Int
  eventName      String
  action         String?
  payload        Json
  enqueuedAt     DateTime @default(now())
  processedAt    DateTime?

  installation   Installation @relation(fields: [installationId], references: [id])

  @@index([installationId])
  @@index([deliveryId])
  @@map("webhook_deliveries")
}

model PrComment {
  id               String   @id @default(uuid())
  installationId   Int
  repositoryId     Int
  prNumber         Int
  githubCommentId  BigInt
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@unique([installationId, repositoryId, prNumber], name: "installationId_repositoryId_prNumber")
  @@index([installationId])
  @@map("pr_comments")
}

model ActionDedup {
  id             String   @id @default(uuid())
  installationId Int
  repositoryId   Int
  detectorType   String
  ref            String
  actionType     String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  @@unique([installationId, repositoryId, detectorType, ref, actionType], name: "installationId_repositoryId_detectorType_ref_actionType")
  @@index([expiresAt])
  @@map("action_dedups")
}

model AutofixPr {
  id             String   @id @default(uuid())
  installationId Int
  repositoryId   Int
  detectorType   String
  sha            String
  branchName     String
  prNumber       Int
  createdAt      DateTime @default(now())
  @@unique([installationId, repositoryId, detectorType, sha], name: "installationId_repositoryId_detectorType_sha")
  @@index([installationId])
  @@map("autofix_prs")
}

model TrackedIssue {
  id                String   @id @default(uuid())
  installationId    Int
  repositoryId      Int
  detectorType      String
  ref               String
  githubIssueNumber Int
  createdAt         DateTime @default(now())
  @@unique([installationId, repositoryId, detectorType, ref], name: "installationId_repositoryId_detectorType_ref")
  @@index([installationId])
  @@map("tracked_issues")
}
