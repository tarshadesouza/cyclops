# ============================================================
# CyclOps — environment variable reference
# Copy this file to .env and fill in real values.
# Never commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# Shared — required by BOTH apps/api and apps/worker
# ------------------------------------------------------------

# Numeric GitHub App ID (GitHub App settings → App ID)
GITHUB_APP_ID=

# RSA private key for JWT signing (replace newlines with literal \n for Railway)
GITHUB_APP_PRIVATE_KEY=

# Shared secret for HMAC webhook verification
GITHUB_WEBHOOK_SECRET=

# PostgreSQL connection string
# Development: postgresql://user:pass@localhost:5432/ciintel
# Production (Railway PgBouncer): postgresql://user:pass@host:6543/db?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Redis connection string
REDIS_URL=redis://localhost:6379

# Pino log level (default: info). Options: trace | debug | info | warn | error
LOG_LEVEL=info

# AES-256-GCM encryption key for BYOK Anthropic API keys stored in the database.
# Generate: openssl rand -hex 32  (produces 64 hex chars = 32 bytes)
# MUST be identical across apps/api and apps/worker.
CYCLOPS_ENCRYPTION_KEY=

# ------------------------------------------------------------
# apps/api only
# ------------------------------------------------------------

# HTTP server port (Railway sets this automatically)
PORT=3000

# Bind address
HOST=0.0.0.0

# Shared secret for the x-setup-token header on POST /setup/:installationId
# Generate: openssl rand -hex 32
CYCLOPS_SETUP_SECRET=

# ------------------------------------------------------------
# apps/worker only
# ------------------------------------------------------------

# Per-installation monthly token cap (default 1 000 000 = ~$2-10/mo at claude-sonnet-5 pricing).
# Set to a low number (e.g. 100) to test budget enforcement.
CYCLOPS_MONTHLY_TOKEN_BUDGET=1000000
